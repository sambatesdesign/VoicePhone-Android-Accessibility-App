    <string name="tts_no_missed_calls">You have no missed calls.</string>
    <string name="tts_missed_calls">You have %1$d missed call from %2$s.</string>
    <string name="tts_missed_calls_plural">You have %1$d missed calls. The most recent was from %2$s.</string>

    <!-- ── Help ── -->
    <string name="tts_help">Here\'s what I can do. Say call followed by a name to make a phone call.
        Say hang up to end a call.
        Say answer to answer an incoming call.
        Say read my messages to hear your texts.
        Say what time is it or what\'s the date for the time and date.
        Say who called me to hear missed calls.</string>

    <!-- ── Setup / permissions ── -->
    <string name="tts_welcome">Welcome to VoicePhone. I need a few permissions to work properly.</string>
    <string name="tts_permission_phone">I need permission to make phone calls on your behalf.</string>
    <string name="tts_permission_contacts">I need permission to read your contacts so I can call people by name.</string>
    <string name="tts_permission_sms">I need permission to read and send text messages for you.</string>
    <string name="tts_permission_audio">I need permission to use the microphone to hear your voice.</string>
    <string name="tts_permission_call_log">I need permission to read your call history.</string>
    <string name="tts_setup_launcher">Please set VoicePhone as your default home screen. I\'ll take you to the settings now.</string>
    <string name="tts_setup_phone_app">Please set VoicePhone as your default phone app. I\'ll take you to the settings now.</string>
    <string name="tts_setup_battery">Please allow VoicePhone to run in the background so I\'m always ready for you.</string>
    <string name="tts_setup_complete">You\'re all set. Touch the screen at any time and tell me what you\'d like to do.</string>

    <!-- ── Notification channel ── -->
    <string name="notification_channel_name">VoicePhone Service</string>
    <string name="notification_channel_description">Keeps VoicePhone running in the background</string>
